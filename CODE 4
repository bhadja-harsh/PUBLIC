# Function to create dictionary from user input
def create_dict(n):
    d = {}
    for i in range(n):
        key = input("Enter key: ")
        value = int(input("Enter value: "))
        d[key] = value
    return d

n1 = int(input("How many elements in Dictionary 1? "))
dict1 = create_dict(n1)

n2 = int(input("How many elements in Dictionary 2? "))
dict2 = create_dict(n2)

n3 = int(input("How many elements in Dictionary 3? "))
dict3 = create_dict(n3)

# Concatenate dictionaries
dict4 = {**dict1, **dict2, **dict3}

print("Concatenated Dictionary:", dict4)
